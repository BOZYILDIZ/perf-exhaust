# ========================================
# PERF'EXHAUST — Variables d'environnement
# ========================================
# Copier ce fichier en .env.local et remplir les valeurs

# --- Resend (envoi d'emails) ---
# Créer un compte sur https://resend.com et générer une clé API
# Sans cette variable, les emails sont loggués en console (mode mock)
RESEND_API_KEY=

# --- Email destinataire atelier ---
# L'email où les demandes de devis/contact seront reçues
BUSINESS_EMAIL=contact@perfexhaust.fr

# --- Instagram API (optionnel) ---
# https://developers.facebook.com/docs/instagram-api
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# --- TikTok API (optionnel) ---
# https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# --- Divers ---
NEXT_PUBLIC_SITE_URL=https://perfexhaust.fr

# --- Panel admin (/admin) ---
# Les trois variables sont requises pour activer l'admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Clé de signature des sessions (longue chaîne aléatoire, ex: openssl rand -hex 32)
ADMIN_SECRET=

# --- Base de données (réalisations gérées via /admin) ---
# PostgreSQL — Neon (https://neon.tech) ou Vercel Postgres recommandés.
# Sans cette variable, le site public utilise les données statiques
# de src/data/projects.ts et l'admin affiche la marche à suivre.
DATABASE_URL=

# --- Upload d'images admin (Vercel Blob) ---
# Sans ce token, l'admin reste utilisable (URLs d'images manuelles).
BLOB_READ_WRITE_TOKEN=

# --- Intégration Pennylane (création de devis depuis /admin/devis) ---
# Sans PENNYLANE_API_KEY, la section Pennylane de /admin/devis/[id] affiche
# "Pennylane non configuré" — rien ne casse. Voir docs/MAINTENANCE.md
# § "Intégration Pennylane" pour la procédure complète.
# Token "Company API" à générer dans Pennylane :
# Management > Settings > Connectivity > Developers > Generate an API Token
# (permissions "Read and write", scopes customers + quotes).
PENNYLANE_API_KEY=
# Optionnel — uniquement si vous utilisez un environnement Pennylane différent
# de la production standard (ex: sandbox de test).
PENNYLANE_BASE_URL=
# Optionnel — non utilisé par le Company API token (une clé Company API est
# déjà scopée à une seule entreprise) ; à renseigner uniquement si Pennylane
# l'exige pour votre configuration spécifique (ex: token cabinet comptable
# multi-entreprises).
PENNYLANE_COMPANY_ID=
