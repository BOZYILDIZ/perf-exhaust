// Schéma Prisma — PERF'EXHAUST
// Base : PostgreSQL (Neon / Vercel Postgres en production, instance locale en dev).
// Voir docs/MAINTENANCE.md § "Panel admin & base de données".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(cuid())
  slug      String   @unique
  status    String   @default("draft") // "draft" | "published"

  // Informations principales
  vehicule    String
  marque      String
  modele      String
  annee       String
  prestation  String
  categorie   String?
  tags        Json     @default("[]") // string[]
  sonoriteTag String
  filterTags  Json     @default("[]") // string[] — pilote les filtres de la galerie

  // Contenu
  description             String
  descriptionComplete     String
  objectifsClient         String  @default("")
  modificationsRealisees  String  @default("")
  materiaux               String  @default("")
  resultatSonore          String  @default("")
  dureeProjet             String?
  difficulte              String?
  ctaCustom               String?

  // Médias
  imagePrincipale String?
  imageAlt        String?
  galerie         Json    @default("[]") // { src, alt, type: "avant"|"apres"|"detail" }[]
  videoUrl        String?

  // SEO
  seoTitle       String?
  seoDescription String?
  ogImage        String?

  // Divers
  featured  Boolean @default(false)
  date      String  @default("") // AAAA-MM-JJ (affichage + sitemap)
  sortOrder Int     @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  @@index([status, sortOrder])
}

// Demandes de devis reçues via /rendez-vous — persistées en plus de l'email
// (mini-CRM atelier). Le formulaire continue de fonctionner même si l'écriture
// en base échoue (voir src/app/api/rendez-vous/route.ts).
model QuoteRequest {
  id  String @id @default(cuid())

  nom          String
  prenom       String
  email        String
  telephone    String
  marque       String
  modele       String
  annee        String
  motorisation String?
  typeProjet   String
  sonorite     String
  message      String

  status String @default("new") // "new" | "contacted" | "in_progress" | "completed" | "archived"
  notes  String @default("") // notes internes atelier, jamais exposées publiquement

  // Intégration Pennylane — voir src/lib/pennylane/. Rien n'est envoyé
  // automatiquement : ces champs ne se remplissent qu'après une action
  // explicite de l'admin sur /admin/devis/[id].
  pennylaneCustomerId  String?
  pennylaneQuoteId     String?
  pennylaneQuoteNumber String?
  pennylaneQuoteUrl    String?
  pennylaneSyncStatus  String?   @default("not_configured") // "not_configured" | "draft" | "synced" | "failed"
  pennylaneSyncError   String?
  pennylaneSyncedAt    DateTime?

  lines QuoteLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// Lignes préparées par l'admin avant l'envoi du devis à Pennylane —
// éditables librement tant que le devis n'a pas été synchronisé.
model QuoteLine {
  id             String   @id @default(cuid())
  quoteRequestId String
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)

  description    String
  quantity       Int    @default(1)
  unitPriceCents Int    @default(0) // prix unitaire HT en centimes — évite les erreurs d'arrondi flottant
  vatRate        Float  @default(20) // taux de TVA en % (20, 10, 5.5, 2.1, 0...)
  sortOrder      Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteRequestId, sortOrder])
}

// Paramètres globaux du site, éditables depuis /admin/settings.
// Ligne unique (id fixe "singleton") — voir src/lib/settings-repo.ts pour le
// fallback sur les valeurs codées en dur tant qu'aucune ligne n'existe.
model SiteSettings {
  id String @id @default("singleton")

  businessName        String  @default("PERF'EXHAUST")
  phone                String  @default("+33636523058")
  email                String  @default("contact@perfexhaust.fr")
  address              String  @default("30 Rue de Soufflenheim")
  postalCode           String  @default("67480")
  city                 String  @default("Rountzenheim-Auenheim")
  instagramUrl         String  @default("https://www.instagram.com/perfexhaust67/")
  tiktokUrl            String  @default("https://www.tiktok.com/@perfexhaust")
  googleReviewsUrl     String  @default("")
  shiftechUrl          String  @default("https://www.shiftech.eu")
  openingHours         String  @default("Lun–Ven : 8h–18h (sur rendez-vous)")
  legalForm            String  @default("")
  siret                String  @default("882 838 667 00021")
  publicationDirector  String  @default("")

  updatedAt DateTime @updatedAt
}

// Prestations affichées sur /services, gérées depuis /admin/services.
// Fallback statique : src/data/services.ts tant qu'aucune ligne n'existe.
model Service {
  id                String   @id @default(cuid())
  title             String
  slug              String   @unique
  shortDescription  String
  longDescription   String   @default("")
  icon              String   @default("wrench")
  status            String   @default("draft") // "draft" | "published"
  sortOrder         Int      @default(0)
  seoTitle          String?
  seoDescription    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sortOrder])
}

// Questions fréquentes affichées sur la home, gérées depuis /admin/faq.
// Fallback statique : liste codée dans src/lib/faq-repo.ts tant qu'aucune
// ligne n'existe. Le schema.org FAQPage est généré depuis les mêmes données.
model FAQItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  status    String   @default("draft") // "draft" | "published"
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sortOrder])
}
